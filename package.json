{
  "name": "llm-test-suite",
  "version": "2.0.0",
  "description": "Comprehensive LLM test suite - basic tests + enterprise compliance testing across standards, personas, and company types",
  "main": "run-all-tests.js",
  "type": "module",
  "scripts": {
    "test": "node run-all-tests.js",
    "test:speed": "node tests/speed-test.js",
    "test:accuracy": "node tests/accuracy-test.js",
    "test:tools": "node tests/tool-calling-test.js",
    "test:context": "node tests/context-window-test.js",
    "enterprise": "node run-enterprise-tests.js",
    "enterprise:stats": "node run-enterprise-tests.js stats",
    "enterprise:pilot": "node run-enterprise-tests.js pilot",
    "enterprise:quick": "node run-enterprise-tests.js quick",
    "enterprise:standard": "node run-enterprise-tests.js standard",
    "enterprise:comprehensive": "node run-enterprise-tests.js comprehensive",
    "enterprise:functions": "node run-enterprise-tests.js function-calling"
  },
  "keywords": [
    "llm",
    "testing",
    "llama.cpp",
    "benchmark",
    "compliance",
    "enterprise",
    "GDPR",
    "ISO27001",
    "SOC2"
  ],
  "author": "Libor Ballaty <libor@arionetworks.com>",
  "license": "MIT",
  "dependencies": {
    "express": "^5.2.1",
    "glob": "^13.0.6"
  }
}
